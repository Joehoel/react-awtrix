{
  "name": "react-awtrix",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "module": "index.ts",
  "exports": {
    ".": "./index.ts",
    "./jsx-runtime": "./jsx-runtime.ts",
    "./jsx-dev-runtime": "./jsx-dev-runtime.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "bun run typecheck && bun run lint && bun run format:check",
    "example:hello": "bun run examples/hello.tsx",
    "example:clock": "bun run examples/clock.tsx",
    "example:progress": "bun run examples/progress.tsx",
    "example:complex": "bun run examples/complex.tsx",
    "example:pomodoro": "bun run examples/pomodoro.tsx",
    "example:mqtt": "bun run examples/mqtt.tsx",
    "example:mqtt:local": "AWTRIX_MQTT_LOCAL_BROKER=1 bun run examples/mqtt.tsx",
    "example:server": "bun --hot examples/server.tsx"
  },
  "dependencies": {
    "aedes": "^1.0.0",
    "arktype": "^2.2.0",
    "mqtt": "^5.15.0",
    "react": "^19.2.4",
    "react-reconciler": "^0.33.0"
  },
  "devDependencies": {
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-reconciler": "^0.33.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "typescript": "^5"
  }
}
