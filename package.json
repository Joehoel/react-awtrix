{
  "name": "react-awtrix",
  "version": "0.0.1",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typesVersions": {
    "*": {
      "jsx-runtime": [
        "./dist/jsx-runtime.d.mts"
      ],
      "jsx-dev-runtime": [
        "./dist/jsx-dev-runtime.d.mts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./jsx-dev-runtime": {
      "import": {
        "types": "./dist/jsx-dev-runtime.d.mts",
        "default": "./dist/jsx-dev-runtime.mjs"
      },
      "require": {
        "types": "./dist/jsx-dev-runtime.d.cts",
        "default": "./dist/jsx-dev-runtime.cjs"
      }
    },
    "./jsx-runtime": {
      "import": {
        "types": "./dist/jsx-runtime.d.mts",
        "default": "./dist/jsx-runtime.mjs"
      },
      "require": {
        "types": "./dist/jsx-runtime.d.cts",
        "default": "./dist/jsx-runtime.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "prepare": "lefthook install",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "lint:fix": "sh -c 'if [ \"$#\" -gt 0 ]; then oxlint --fix \"$@\"; else oxlint --fix; fi' --",
    "format": "sh -c 'if [ \"$#\" -gt 0 ]; then oxfmt --write \"$@\"; else oxfmt --write .; fi' --",
    "format:check": "oxfmt --check .",
    "knip": "knip",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run knip",
    "example:hello": "bun run examples/hello.tsx",
    "example:clock": "bun run examples/clock.tsx",
    "example:progress": "bun run examples/progress.tsx",
    "example:complex": "bun run examples/complex.tsx",
    "example:pomodoro": "bun run examples/pomodoro.tsx",
    "example:mqtt": "bun run examples/mqtt.tsx",
    "example:mqtt:local": "AWTRIX_MQTT_LOCAL_BROKER=1 bun run examples/mqtt.tsx",
    "example:server": "bun --hot examples/server.tsx"
  },
  "dependencies": {
    "aedes": "^1.0.0",
    "arktype": "^2.2.0",
    "mqtt": "^5.15.0",
    "react": "^19.2.4",
    "react-reconciler": "^0.33.0"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-reconciler": "^0.33.0",
    "knip": "^5.85.0",
    "lefthook": "^1.7.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "publint": "^0.3.18",
    "tsdown": "^0.21.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "typescript": "^5"
  }
}
